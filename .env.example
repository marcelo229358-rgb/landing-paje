# Dados de exemplo (padrão). Defina como "false" para buscar da API.
NEXT_PUBLIC_USE_MOCK_DATA=true

# URL da API (opcional)
# NEXT_PUBLIC_API_URL=http://localhost:3001

# URL do site (sitemap e robots)
# NEXT_PUBLIC_SITE_URL=https://deploysolucoes.com.br

# Webhook Make.com (notificações de intenção de compra)
# NEXT_PUBLIC_MAKE_WEBHOOK_URL=https://hook.us2.make.com/seu-webhook
# KIWIFY_WEBHOOK_TOKEN=seu-token-do-webhook
# WHATSAPP_NOTIFY_PHONE=5581991821954
# NOTIFY_EMAIL=contato@deploysolucoes.com.br

# Opção 1: CallMeBot (grátis) — envie "I allow callmebot to send me messages" para +34 644 44 71 67
# CALLMEBOT_API_KEY=sua-chave

# Opção 2: Z-API
# ZAPI_INSTANCE_ID=
# ZAPI_TOKEN=
# ZAPI_CLIENT_TOKEN=
